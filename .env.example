# ─────────────────────────────────────────────────────────────
# Meta App — consegue em developers.facebook.com
# ─────────────────────────────────────────────────────────────
META_APP_ID=seu_app_id_aqui
META_APP_SECRET=seu_app_secret_aqui
META_REDIRECT_URI=https://SEU-SITE.netlify.app/api/auth-callback
# Redirect para o fluxo Instagram Login (sem Página do Facebook)
META_REDIRECT_URI_IG=https://SEU-SITE.netlify.app/api/auth-callback-ig

# ─────────────────────────────────────────────────────────────
# Frontend (prefixo VITE_ expõe ao React)
# ─────────────────────────────────────────────────────────────
VITE_META_APP_ID=seu_app_id_aqui

# ─────────────────────────────────────────────────────────────
# Cloudflare R2 — NUNCA exponha estas chaves no código-fonte!
# Configure no painel do Netlify em: Site Settings > Environment Variables
# ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=seu_account_id_cloudflare
R2_ACCESS_KEY=sua_access_key_r2
R2_SECRET_KEY=sua_secret_key_r2
R2_BUCKET=insta-midias
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.r2.dev

# ─────────────────────────────────────────────────────────────
# CORS — domínio autorizado a chamar as Netlify Functions
# Use a URL completa do seu site (sem barra no final)
# O Netlify já popula a variável URL automaticamente em produção
# ─────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://SEU-SITE.netlify.app
